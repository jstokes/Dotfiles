[user]
  name = Jeff Stokes
  email = jeffecu88@gmail.com
[include]
  path = ~/.gitconfig.work
[core]
  excludesfile = ~/.gitignore_global
  repositoryformatversion = 0
  filemode = true
  bare = false
  logallrefupdates = true
  ignorecase = false
  editor = nvim
  autocrlf = input
[alias]
  us = reset HEAD
  uc = reset --soft HEAD^
  pl = smart-pull
  ph = push
  phf = push --force-with-lease
  st = status -s
  co = checkout
  ci = commit -v
  br = branch --sort=-committerdate
  df = diff
  dfs = diff --stat
  dfp = diff head~
  dc = diff --cached
  aa = add -A
  ai = add -i
  lol = log --graph --decorate --pretty=oneline --abbrev-commit
  lola = log --graph --decorate --pretty=oneline --abbrev-commit --all
  lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
  rh = reset --hard
  m = smart-merge
  l = smart-log
  cb = checkout -b
  nmp = log head "^master" --pretty=oneline --no-merges
  nm = log head "^master" --no-merges
  review = !git push origin HEAD:refs/for/`git rev-parse --abbrev-ref HEAD`
  dfc = diff --color-words
  sh = show head --format="%H" -s
  wt = worktree
  wta = "!f() { branch=\"$1\"; from=\"$2\"; if [ -z \"$branch\" ]; then echo \"Usage: git wta <branch> [branch-from]\"; return 2; fi; if [ -z \"$from\" ]; then from=\"origin/main\"; fi; root=\"$(git rev-parse --show-toplevel 2>/dev/null)\" || { echo \"Not a git repository\"; return 2; }; path=\"$root/.trees/$branch\"; mkdir -p \"$path\"; git fetch --quiet origin \"$branch\" >/dev/null 2>&1 || true; if git show-ref --verify --quiet \"refs/heads/$branch\"; then git worktree add \"$path\" \"$branch\"; elif git show-ref --verify --quiet \"refs/remotes/origin/$branch\"; then git worktree add --track -b \"$branch\" \"$path\" \"origin/$branch\"; else git worktree add -b \"$branch\" \"$path\" \"$from\"; fi; cd \"$path\" || exit 1; if [ -t 1 ]; then exec \"${SHELL:-bash}\"; fi; }; f"
  wtl = worktree list
  wtr = worktree remove
  wtm = worktree move
[fetch]
  prune = true
[color]
  ui = true
[push]
  default = current
[help]
  autocorrect = 1
[pull]
  rebase = true
[rerere]
  enabled = true
[diff]
  external = difft
[github]
  user = jstokes
